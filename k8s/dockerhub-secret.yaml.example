# ==============================================================
# Docker Hub pull credentials (PRIVATE backend image)
# ==============================================================
# 1. Copy this file:
#      cp dockerhub-secret.yaml.example dockerhub-secret.yaml
# 2. Replace YOUR_DOCKERHUB_ACCESS_TOKEN_HERE with a read-only PAT from:
#      https://hub.docker.com/settings/security
# 3. Apply in order:
#      kubectl apply -f k8s/namespace.yaml
#      kubectl apply -f k8s/dockerhub-secret.yaml
#      kubectl apply -f k8s/posturesec.yaml
#
# dockerhub-secret.yaml is gitignored — never commit real tokens.
# ==============================================================

apiVersion: v1
kind: Secret
metadata:
  name: dockerhub-secret
  namespace: posturesec
  labels:
    app.kubernetes.io/part-of: posturesec
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "https://index.docker.io/v1/": {
          "username": "hacksoull",
          "password": "YOUR_DOCKERHUB_ACCESS_TOKEN_HERE",
          "email": "your-email@example.com"
        }
      }
    }
