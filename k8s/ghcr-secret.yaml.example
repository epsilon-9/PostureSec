# ==============================================================
# GitHub Container Registry (GHCR) pull credentials
# ==============================================================
# Required when GHCR packages are private (default for CI-built images).
#
# 1. Create a PAT with read:packages scope:
#      https://github.com/settings/tokens
# 2. Copy this file:
#      cp ghcr-secret.yaml.example ghcr-secret.yaml
# 3. Replace YOUR_GITHUB_USERNAME and YOUR_GITHUB_PAT_HERE
# 4. Apply in order:
#      kubectl apply -f k8s/namespace.yaml
#      kubectl apply -f k8s/ghcr-secret.yaml
#      kubectl apply -f k8s/posturesec.yaml
#
# ghcr-secret.yaml is gitignored — never commit real tokens.
# ==============================================================

apiVersion: v1
kind: Secret
metadata:
  name: ghcr-secret
  namespace: posturesec
  labels:
    app.kubernetes.io/part-of: posturesec
type: kubernetes.io/dockerconfigjson
stringData:
  .dockerconfigjson: |
    {
      "auths": {
        "ghcr.io": {
          "username": "YOUR_GITHUB_USERNAME",
          "password": "YOUR_GITHUB_PAT_HERE",
          "email": "your-email@example.com"
        }
      }
    }
